{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": ["./*"],
      "@common/*": ["common/*"],
      "@config/*": ["config/*"],
      "@auth/*": ["auth/*"],
      "@users/*": ["users/*"],
      "@sections/*": ["sections/*"],
      "@products/*": ["products/*"],
      "@warehouses/*": ["warehouses/*"],
      "@images/*": ["images/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
